from tqdm.auto import tqdm

def create_rodeo_cycle(t_list, E_target, J, h, num_qubits, trotter_steps=10):
    """
    Creates the complete Rodeo Algorithm circuit using a predefined list of times.
    """
    ciclos = len(t_list)
    qr_sys = QuantumRegister(num_qubits, 'sys')
    qr_anc = QuantumRegister(1, 'anc')
    cr_anc = ClassicalRegister(1, 'meas')
    qc = QuantumCircuit(qr_sys, qr_anc, cr_anc)

    qc.x(qr_anc)

    for m in range(ciclos):
        t = t_list[m]
        dt = t / trotter_steps

        # 1 and 2. Initialization and Hadamard
        qc.h(qr_anc)

        # 3. Controlled Trotterization
        for _ in range(trotter_steps):
            # X Term (Transverse Field)
            for i in range(num_qubits):
                qc.crx(-2 * h * dt, qr_anc, qr_sys[i])
            # ZZ Term (Ising)
            for i in range(num_qubits - 1):
                qc.cx(qr_sys[i], qr_sys[i+1])
                qc.crz(-2 * J * dt, qr_anc, qr_sys[i+1])
                qc.cx(qr_sys[i], qr_sys[i+1])

        # 4. Ancilla Phase
        qc.p(E_target * t , qr_anc)

        # 5 and 6. Final Hadamard and Measurement
        qc.h(qr_anc)
        qc.measure(qr_anc, cr_anc)
        
        # CONDITIONAL RETURN GATE POST MEASUREMENT
        # IF MEASURED 0:
        # Just reset the phase
        qc.p(-E_target * t , qr_anc)
        
        # IF MEASURED 1:
        # Reset the phase and NOT
        qc.p(-E_target * t , qr_anc)
        qc.x(qr_anc)

    return qc

# --- Simulation Parameters ---
J_coupling = 1.0
h_field = 1.5
num_qubits = 4
ciclos = 10        # Number of rodeo cycles (filter size)
shots = 1000

# 1. Generate the fixed random times (t_n) for this scan using a Gaussian
t_rms = 5.0
t_list = np.random.normal(0, t_rms, ciclos)

# 2. Prepare the energy scan
E_scan = np.linspace(-8, 8, 50) # 50 points between -8 and 8
prob_sucesso = []

print("Downloading IBM Manila noise profile and topology (5 qubits)...")

# 1. Instantiates the physical machine's "digital twin"
maquina_real = FakeManilaV2()

# 2. Extracts the exact noise model (Thermal T1/T2 errors, gate errors, measurement errors)
noise_model = NoiseModel.from_backend(maquina_real)

# 3. Extracts the topology (the physical map of wires connecting the 5 qubits)
topologia = maquina_real.coupling_map

# 4. Simulator configuration with IBM hardware
backend = AerSimulator(noise_model=noise_model, coupling_map=topologia)

pm = generate_preset_pass_manager(backend=backend, optimization_level=3)

print("Starting energy scan in Qiskit...")

# 3. Execute the circuit for each E_target value
#sucesso_str = "1" * ciclos

# ---> CHANGE HERE: For loop wrapped by tqdm <---
for E in tqdm(E_scan, desc="Simulation Progress"):
    # Creates the circuit with the current iteration's energy
    qc = create_rodeo_cycle(t_list, E, J_coupling, h_field, num_qubits)
    transpiled_qc = pm.run(qc)

    # Executes the circuit
    result = backend.run(transpiled_qc, shots=shots).result()
    counts = result.get_counts()

    # Extracts the number of times ALL ancillas yielded 1
    sucessos = counts.get("1", 0)
    prob_sucesso.append(sucessos / shots)

print("\nSimulation completed!")

# --- 4. Plot the Result ---
plt.figure(figsize=(10, 6))
plt.plot(E_scan, prob_sucesso, 'b-o', linewidth=2, label=f'Qiskit Signal ({ciclos} cycles)')
plt.xticks(np.arange(-7.5, 7.5, step=2.5))
plt.title(f'Simulated Spectrum in Qiskit (Ising Model L={num_qubits})')
plt.xlabel('Target Energy (E_target)')
plt.ylabel('Success Probability P(N)')
plt.grid(True, alpha=0.3)
plt.legend()
plt.tight_layout()
plt.show()
