#Variação no codigo para gerar um plot Probabilidade x Energias
import numpy as np
import matplotlib.pyplot as plt
import random
from qiskit import QuantumCircuit, QuantumRegister, ClassicalRegister
from qiskit_aer import AerSimulator
from qiskit.transpiler.preset_passmanagers import generate_preset_pass_manager

def create_rodeo_cycle(t_list, E_target, J, h, num_qubits, trotter_steps=20):
    """
    Cria o circuito completo do Algoritmo de Rodeio usando uma lista predefinida de tempos.
    """
    ciclos = len(t_list)
    qr_sys = QuantumRegister(num_qubits, 'sys')
    qr_anc = QuantumRegister(ciclos, 'anc')
    cr_anc = ClassicalRegister(ciclos, 'meas')
    qc = QuantumCircuit(qr_sys, qr_anc, cr_anc)

    for m in range(ciclos):
        t = t_list[m]
        dt = t / trotter_steps

        # 1 e 2. Inicialização e Hadamard
        qc.x(qr_anc[m])
        qc.h(qr_anc[m])

        # 3. Trotterização controlada
        for _ in range(trotter_steps):
            # Termo X (Campo Transverso)
            for i in range(num_qubits):
                qc.crx(-2 * h * dt, qr_anc[m], qr_sys[i])
            # Termo ZZ (Ising)
            for i in range(num_qubits - 1):

                qc.cx(qr_sys[i], qr_sys[i+1])
                qc.crz(-2 * J * dt, qr_anc[m], qr_sys[i+1])
                qc.cx(qr_sys[i], qr_sys[i+1])

        # 4. Fase da Ancila
        qc.p(E_target * t, qr_anc[m])

        # 5 e 6. Hadamard final e Medição
        qc.h(qr_anc[m])
        qc.measure(qr_anc[m], cr_anc[m])

    return qc

# --- Parâmetros da Simulação ---
J_coupling = 1.0
h_field = 1.5
num_qubits = 4
ciclos = 10        # Número de ciclos do rodeio (tamanho do filtro)
shots = 20000

# 1. Gerar os tempos aleatórios fixos (t_n) para este scan usando Gaussiana
# t_RMS define a largura do filtro de energia.
t_rms = 5.0
t_list = np.random.normal(0, t_rms, ciclos)

# 2. Preparar a varredura de energia
E_scan = np.linspace(-8, 8, 300) # 40 pontos entre -4 e 4
prob_sucesso = []

# Configuração do simulador
backend = AerSimulator()
pm = generate_preset_pass_manager(backend=backend, optimization_level=1)

print("Iniciando varredura de energia no Qiskit...")

# 3. Executar o circuito para cada valor de E_target
sucesso_str = "1" * ciclos  # A string de medição alvo (ex: '1111')

for E in E_scan:
    # Cria o circuito com a energia da iteração atual e OS MESMOS tempos t_list
    qc = create_rodeo_cycle(t_list, E, J_coupling, h_field, num_qubits)
    transpiled_qc = pm.run(qc)

    # Executa o circuito
    result = backend.run(transpiled_qc, shots=shots).result()
    counts = result.get_counts()

    # Extrai o número de vezes que TODAS as ancilas deram 1
    sucessos = counts.get(sucesso_str, 0)
    prob_sucesso.append(sucessos / shots)

print("Simulação concluída!")

# --- 4. Plotar o Resultado ---
plt.figure(figsize=(10, 6))
plt.plot(E_scan, prob_sucesso, 'b-o', linewidth=2, label=f'Qiskit Signal ({ciclos} cycles)')
plt.xticks(np.arange(-7.5, 7.5, step=2.5))
plt.title(f'Simulated Spectrum in Qiskit (Ising Model L={num_qubits})')
plt.xlabel('Target Energy (E_target)')
plt.ylabel('Success Probability P(N)')
plt.grid(True, alpha=0.3)
plt.legend()
plt.tight_layout()
plt.show()
